{
  "name": "memtree",
  "description": "Tree/graph-based persistent context store with surgical recall. Exposes memtree.read, memtree.grep, memtree.compose, memtree.search, memtree.neighbors for budget-bounded recall.",
  "author": { "name": "Joe Black", "email": "joeblackwaslike@gmail.com" },
  "homepage": "https://github.com/joeblackwaslike/memtree",
  "repository": "https://github.com/joeblackwaslike/memtree",
  "license": "MIT",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Bash|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-proxy.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"${HOME}/.memtree/proxy-mode\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "memtree": {
      "command": "bun",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/dist/server.js"],
      "env": {
        "MEMTREE_CWD": "${workspaceFolder}"
      }
    }
  }
}

{
  "name": "memtree",
  "description": "Tree/graph-based persistent context store with passive capture and surgical recall. Captures Read/Grep/Bash tool outputs via PostToolUse hook.",
  "author": { "name": "Joe Black", "email": "joeblackwaslike@gmail.com" },
  "homepage": "https://github.com/joeblackwaslike/memtree",
  "repository": "https://github.com/joeblackwaslike/memtree",
  "license": "MIT",
  "mcpServers": {
    "memtree": {
      "command": "bun",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/dist/server.js"],
      "env": {
        "MEMTREE_CWD": "${workspaceFolder}"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/mcp/hooks/capture.sh" }
        ]
      }
    ]
  }
}
